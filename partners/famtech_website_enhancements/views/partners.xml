            <style>
                :root {
                --brand-primary: #062647;
                --brand-primary-light: #0b3a6b;

                /* UPDATED: Premium Metallic/Champagne Gold */
                --brand-gold: #D4AF37;
                --brand-gold-hover: #B5952F;
                --o-cc2-link: #D4AF37;
                --o-cc2-btn-primary: #B5952F;

                --text-muted: #64748b;

                /* UPDATED: Eye-friendly Soft White */
                --soft-white: #fafafa;

                --transition-smooth: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
                }

                .page-wrapper {
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                color: #333;
                overflow-x: hidden;
                }

                /* ================= HERO ================= */
                .hero-section { background: linear-gradient(135deg, var(--brand-primary),
                var(--brand-primary-light)); position: relative; overflow: hidden; padding: 120px 0;
                }
                .hero-section::before, .hero-section::after { content: ""; position: absolute;
                border-radius: 50%; background: rgba(212, 175, 55, 0.08); animation: float 8s
                ease-in-out infinite; z-index: 0; }
                .hero-section::before { width: 400px; height: 400px; top: -150px; right: -100px; }
                .hero-section::after { width: 300px; height: 300px; bottom: -120px; left: -80px;
                animation-delay: -4s; }
                .hero-content { position: relative; z-index: 1; }
                .gold-text { color: var(--brand-gold); }

                .btn-gold { background: var(--brand-gold); color: white;
                border-radius: 40px; font-weight: 600; transition: var(--transition-smooth); border:
                none; padding: 12px 30px; display: inline-block; text-decoration: none; }
                .btn-gold:hover { background: var(--brand-gold-hover); color: white;
                transform: translateY(-2px); box-shadow: 0 8px 20px rgba(212, 175, 55, 0.25); }

                /* ================= SMOOTH LOGO SLIDER ================= */
                .logo-slider { overflow: hidden; padding: 60px 0; background: var(--soft-white);
                position:
                relative; }
                .logo-slider::before, .logo-slider::after { content: ""; position: absolute; top: 0;
                width: 150px; height: 100%; z-index: 2; pointer-events: none; }
                .logo-slider::before { left: 0; background: linear-gradient(to right,
                var(--soft-white),
                transparent); }
                .logo-slider::after { right: 0; background: linear-gradient(to left,
                var(--soft-white),
                transparent); }
                .logo-track { display: flex; align-items: center; gap: 80px; width: max-content;
                animation: logoScroll 40s linear infinite; will-change: transform; }
                @keyframes logoScroll { 0% { transform: translate3d(0, 0, 0); } 100% { transform:
                translate3d(-50%, 0, 0); } }
                .logo-item { flex: 0 0 auto; width: 160px; display: flex; justify-content: center;
                align-items: center; }
                .logo-item img { max-width: 100%; max-height: 60px; object-fit: contain; filter:
                grayscale(100%) opacity(0.6); transition: var(--transition-smooth); }
                .logo-item img:hover { filter: grayscale(0%) opacity(1); transform: scale(1.05); }

                /* ================= VALUES ================= */
                .values-section { background: var(--soft-white); padding: 100px 20px; }
                .section-header { text-align: center; max-width: 700px; margin: auto auto 60px; }
                .section-header h2 { font-weight: 800; color: var(--brand-primary); margin-bottom:
                15px; letter-spacing: -0.5px; }
                .section-header p { color: var(--text-muted); font-size: 1.1rem; }

                .value-card { background: var(--soft-white); border-radius: 16px; padding: 40px
                30px;
                text-align: center; border: 1px solid rgba(0, 0, 0, 0.03); transition:
                var(--transition-smooth); height: 100%; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
                }
                .value-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(6, 38,
                71, 0.08); border-color: rgba(212, 175, 55, 0.3); }
                .icon-circle { width: 70px; height: 70px; border-radius: 50%; display: flex;
                align-items: center; justify-content: center; margin: 0 auto 25px; background:
                rgba(212, 175, 55, 0.1); font-size: 28px; color: var(--brand-primary); transition:
                var(--transition-smooth); }
                .value-card:hover .icon-circle { background: var(--brand-gold); color:
                white; transform: scale(1.1) rotate(5deg); }
                .value-title { font-weight: 700; font-size: 1.25rem; margin-bottom: 12px; color:
                var(--brand-primary); }
                .value-text { font-size: 0.95rem; color: #596780; line-height: 1.6; }

                /* ================= TESTIMONIAL ================= */
                .testimonial-section { background: var(--soft-white); padding: 100px 20px; }
                .testimonial-card { background: var(--soft-white); border-radius: 20px; padding:
                45px; border:
                1px solid #f1f5f9; display: flex; flex-direction: column; height: 100%; transition:
                var(--transition-smooth); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03); position:
                relative; }
                .testimonial-card:hover { transform: translateY(-8px); box-shadow: 0 25px 50px
                rgba(6, 38, 71, 0.08); }
                .quote-icon { font-size: 2.5rem; color: rgba(212, 175, 55, 0.4); margin-bottom:
                15px;
                line-height: 1; }
                .testimonial-text { font-size: 1.05rem; color: #475569; line-height: 1.7;
                margin-bottom: 30px; flex-grow: 1; font-style: italic; }
                .partner-info { display: flex; align-items: center; gap: 15px; border-top: 1px solid
                #f1f5f9; padding-top: 20px; }
                .partner-img { width: 55px; height: 55px; border-radius: 50%; object-fit: cover; }
                .partner-name { font-weight: 700; color: var(--brand-primary); }
                .partner-company { font-size: 0.85rem; color: var(--text-muted); font-weight: 500; }
                .rating { color: var(--brand-gold); font-size: 1rem; margin-bottom: 15px; }

                /* ================= CTA ================= */
                .cta-section { background: var(--brand-primary); position: relative; overflow:
                hidden; }

                /* Scroll Animation Classes */
                .scroll-animate { opacity: 0; transform: translateY(40px); transition: opacity 0.8s
                ease-out, transform 0.8s ease-out; will-change: opacity, transform; }
                .scroll-animate.show { opacity: 1; transform: translateY(0); }
                .delay-100 { transition-delay: 100ms; }
                .delay-200 { transition-delay: 200ms; }
                .delay-300 { transition-delay: 300ms; }
                @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform:
                translateY(-20px); } }

                /* ================= IMMERSIVE VISUAL HEADLINE SHOWCASE ================= */
                .headline-section {
                background-color: var(--brand-primary);
                background-image:
                url('https://images.unsplash.com/photo-1518770660439-4636190af475');
                background-size: cover;
                background-position: center;
                background-blend-mode: soft-light;
                position: relative;
                padding: 120px 0;
                color: white;
                overflow: hidden;
                border-top: 1px solid rgba(255, 255, 255, 0.05);
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                }

                .headline-section::before {
                content: "";
                position: absolute;
                width: 1000px;
                height: 1000px;
                background: radial-gradient(circle, rgba(11, 58, 107, 0.4) 0%, transparent 65%),
                url('https://images.unsplash.com/photo-1451187580459-43490279c0fa');
                background-size: cover;
                top: 50%;
                right: -300px;
                transform: translateY(-50%);
                z-index: 0;
                border-radius: 50%;
                opacity: 0.6;
                pointer-events: none;
                transition: transform 1.2s ease-out;
                }

                .headline-section.show::before { transform: translateY(-48%) translateX(-20px); }
                .headline-content { position: relative; z-index: 10; }
                .headline-badge { color: var(--brand-gold); font-size: 0.75rem; font-weight: 800;
                letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1.5rem; display:
                inline-block; border-bottom: 2px solid var(--brand-gold); padding-bottom: 4px; }
                .news-highlight-list { display: flex; flex-direction: column; gap: 15px; }
                .news-highlight-item { border-left: 3px solid rgba(255, 255, 255, 0.1); padding:
                30px; transition: var(--transition-smooth); background: rgba(11, 58, 107, 0.3);
                backdrop-filter: blur(5px); border-radius: 0 16px 16px 0; cursor: pointer;
                text-decoration: none; display: block; position: relative; overflow: hidden; }
                .news-highlight-item:hover { border-left-color: var(--brand-gold); background:
                rgba(11, 58, 107, 0.8); transform: translateX(20px); box-shadow: 0 20px 40px rgba(0,
                0, 0, 0.2); }
                .news-highlight-item::after { content: ""; position: absolute; top: 0; left: -100%;
                width: 100%; height: 100%; background: linear-gradient(120deg, transparent,
                rgba(212, 175, 55, 0.1), transparent); transition: 0.6s; }
                .news-highlight-item:hover::after { left: 100%; }

                .highlight-meta { color: rgba(255, 255, 255, 0.6); font-size: 0.8rem; font-weight:
                600; letter-spacing: 1px; margin-bottom: 10px; text-transform: uppercase; }
                .highlight-title { color: white; font-size: 1.4rem; font-weight: 600; line-height:
                1.4; margin-bottom: 12px; transition: color 0.3s ease; }
                .news-highlight-item:hover .highlight-title { color: var(--brand-gold); }
                .highlight-link-text { color: rgba(255, 255, 255, 0.8); font-size: 0.9rem;
                font-weight: 600; transition: color 0.3s ease; display: flex; align-items: center; }
                .highlight-link-text i { transition: transform 0.3s ease; }
                .news-highlight-item:hover .highlight-link-text { color: white; }
                .news-highlight-item:hover .highlight-link-text i { transform: translateX(5px); }
                .case-study-main:hover { transform: scale(1.02); box-shadow: 0 20px 40px rgba(6, 38,
                71, 0.2) !important; }
                .industry-card { background: var(--soft-white); border: 1px solid #eef2f6;
                border-radius: 16px;
                padding: 30px; text-align: center; height: 100%; transition: all 0.3s ease; cursor:
                pointer; display: flex; flex-direction: column; justify-content: center;
                align-items: center; }
                .industry-card h5 { font-weight: 700; color: var(--brand-primary); margin-bottom: 0;
                }
