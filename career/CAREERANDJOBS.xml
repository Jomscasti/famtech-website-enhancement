          .ft-partners-track-wrap::after { right: 0; background: linear-gradient(to left, var(--fam-mist), transparent); }
          .ft-partners-track { display: flex; gap: 2.5rem; align-items: center; width: max-content; animation: ftScroll 30s linear infinite; }
          .ft-partners-track:hover { animation-play-state: paused; }
