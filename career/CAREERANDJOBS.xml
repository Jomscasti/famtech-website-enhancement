          .ft-heading { font-family: 'Inter', sans-serif; font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800; line-height: 1.18; color: var(--fam-ink); margin-bottom: 1rem; }
          .ft-subtext { font-size: 1.05rem; color: var(--fam-slate); line-height: 1.7; max-width: 560px; }
          
          /* CTA Banner */
          .ft-cta-banner {
            background: linear-gradient(135deg, var(--fam-navy) 0%, var(--fam-navy2) 100%);
            padding: 4rem 2rem; text-align: center; position: relative; overflow: hidden;
          }
          .ft-cta-banner h2 { font-family: 'Inter', sans-serif; font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; position: relative; z-index: 1; }
          .ft-cta-banner h2 span { color: var(--fam-gold); }
          .ft-cta-banner p { color: rgba(255,255,255,0.7); font-size: 1.05rem; margin-bottom: 2rem; position: relative; z-index: 1; }
          .ft-cta-banner .ft-cta-btn {
            display: inline-flex; align-items: center; gap: 0.6rem;
            background: var(--fam-gold); color: var(--fam-ink);
            padding: 1rem 2.5rem; border-radius: 6px; font-weight: 700;
