          .ft-partner-logo:hover { opacity: 1; transform: scale(1.08); filter: grayscale(0); }
          
          /* About */
          .ft-about-section { background: #fff; }
          .ft-about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
          .ft-about-image { position: relative; border-radius: 20px; overflow: hidden; box-shadow: 0 32px 80px rgba(6,38,71,0.15); }
