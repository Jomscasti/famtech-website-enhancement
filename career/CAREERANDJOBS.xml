            box-shadow: 0 4px 24px rgba(201,168,76,0.4);
          }
          .ft-cta-banner .ft-cta-btn:hover { background: #e8c456; transform: translateY(-2px); color: var(--fam-ink); text-decoration: none; }
          
          /* Products */
          .ft-products-section { background: var(--fam-mist); }
          .ft-products-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3.5rem; gap: 2rem; }
          .ft-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
          .ft-product-card {
            background: #fff; border-radius: 16px; overflow: hidden;
            border: 1px solid var(--fam-border);
            transition: transform 0.35s, box-shadow 0.35s;
            position: relative;
          }
          .ft-product-card:first-child { grid-column: span 2; }
          .ft-product-card:hover { transform: translateY(-6px); box-shadow: 0 24px 56px rgba(6,38,71,0.12); }
          .ft-product-card-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; transition: transform 0.5s ease; }
          .ft-product-card:first-child .ft-product-card-img { aspect-ratio: 21/9; }
          .ft-product-card:hover .ft-product-card-img { transform: scale(1.04); }
          .ft-product-card-body { padding: 1.5rem; }
          .ft-product-card-tag {
            display: inline-block; font-size: 0.7rem; font-weight: 600;
