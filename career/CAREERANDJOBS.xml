          .ft-bottom-cta h2 em { font-style: normal; color: var(--fam-gold); font-weight: 300; }
          .ft-bottom-cta p { color: rgba(255,255,255,0.65); font-size: 1.1rem; margin-bottom: 2.5rem; }
          .ft-bottom-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
          
          /* Responsive */
          @media (max-width: 992px) {
            .ft-stats-inner { grid-template-columns: repeat(2,1fr); }
            .ft-products-grid { grid-template-columns: 1fr; }
            .ft-product-card:first-child { grid-column: span 1; }
            .ft-solutions-inner { grid-template-columns: 1fr; }
            .ft-solutions-right { min-height: 320px; }
            .ft-solutions-left { padding: 4rem 2rem; max-width: 100%; }
            .ft-media-grid { grid-template-columns: 1fr 1fr; }
            .ft-about-inner { grid-template-columns: 1fr; }
            .ft-products-header { flex-direction: column; align-items: flex-start; }
          }
          @media (max-width: 600px) {
            .ft-stats-inner { grid-template-columns: 1fr 1fr; }
            .ft-hero-actions { flex-direction: column; align-items: center; }
            .ft-media-grid { grid-template-columns: 1fr; }
            .ft-scroll-hint { display: none; }
          }
        </style>

