          .ft-partners-track-wrap { overflow: hidden; position: relative; width: 100%; }
          .ft-partners-track-wrap::before, .ft-partners-track-wrap::after {
            content: ''; position: absolute; top: 0; bottom: 0; width: 120px; z-index: 2; pointer-events: none;
          }
