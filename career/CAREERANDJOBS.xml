          .ft-solutions-right:hover img { opacity: 0.8; transform: scale(1.03); }
          .ft-solutions-right-overlay { position: absolute; inset: 0; background: linear-gradient(to right, var(--fam-navy) 0%, transparent 40%); }
          
          /* Media Showcase */
          .ft-media-section { background: #fff; }
          .ft-media-header { text-align: center; margin-bottom: 3.5rem; }
          .ft-media-header .ft-label { justify-content: center; }
          .ft-media-header .ft-label::before { display: none; }
          .ft-media-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
