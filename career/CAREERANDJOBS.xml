            --fam-navy2: #0a3d6b;
            --fam-gold: #c9a84c;
            --fam-gold2: rgba(201,168,76,0.15);
            --fam-ink: #0d1117;
            --fam-slate: #4a5568;
            --fam-mist: #f4f6f9;
            --fam-border: #e2e6ed;
          }
          * { box-sizing: border-box; margin: 0; padding: 0; }
          body { font-family: 'DM Sans', sans-serif; color: var(--fam-ink); overflow-x: hidden; }
          
          /* Hero */
          .ft-hero {
            position: relative; min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden; background: var(--fam-ink);
          }
          .ft-hero-slides { position: absolute; inset: 0; z-index: 0; }
          .ft-hero-slide {
            position: absolute; inset: 0;
            background-size: cover; background-position: center;
            opacity: 0; transition: opacity 1.8s ease-in-out;
            filter: brightness(0.38);
            animation: ftHeroZoom 20s ease-in-out infinite alternate;
          }
          .ft-hero-slide.active { opacity: 1; }
          .ft-hero-slide:nth-child(1){ background-image:url('/web/image/57744-50580466/1000092006.webp'); animation-delay:0s; }
          .ft-hero-slide:nth-child(2){ background-image:url('/web/image/57651-979cd3f7/1000091747.webp'); animation-delay:-7s; }
          .ft-hero-slide:nth-child(3){ background-image:url('/web/image/57486-01e174dc/1000091703.webp'); animation-delay:-14s; }
          @keyframes ftHeroZoom {
            from { transform: scale(1.07) translateX(0); }
            to { transform: scale(1.0) translateX(-1.5%); }
          }
          .ft-hero-overlay {
            position: absolute; inset: 0; z-index: 1; pointer-events: none;
            background: linear-gradient(135deg, rgba(6,38,71,0.72) 0%, rgba(13,17,23,0.4) 60%, transparent 100%);
          }
          .ft-hero-content {
            position: relative; z-index: 3;
            max-width: 900px; padding: 2rem; text-align: center; color: #fff;
          }
          .ft-hero-badge {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.4);
            color: var(--fam-gold); border-radius: 30px;
            font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em;
            text-transform: uppercase; padding: 0.35rem 1rem; margin-bottom: 1.75rem;
            opacity: 0; animation: ftFadeUp 1s 0.2s ease forwards;
          }
          .ft-hero h1 {
            font-family: 'Inter', sans-serif;
            font-size: clamp(2.8rem, 7vw, 5.5rem);
            font-weight: 800; line-height: 1.08; margin-bottom: 1.5rem;
            opacity: 0; animation: ftFadeUp 1s 0.4s ease forwards;
          }
          .ft-hero h1 .ft-gold { color: var(--fam-gold); font-weight: 300; }
          .ft-hero-sub {
            font-size: clamp(1rem, 1.8vw, 1.2rem);
            color: rgba(255,255,255,0.72); max-width: 600px; margin: 0 auto 2.5rem;
            line-height: 1.7; opacity: 0; animation: ftFadeUp 1s 0.6s ease forwards;
          }
          .ft-hero-actions {
            display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
            opacity: 0; animation: ftFadeUp 1s 0.8s ease forwards;
          }
          @keyframes ftFadeUp {
            from { opacity: 0; transform: translateY(28px); }
            to { opacity: 1; transform: translateY(0); }
          }
          .ft-btn-primary {
            display: inline-flex; align-items: center; gap: 0.5rem;
            padding: 0.9rem 2.2rem; background: var(--fam-gold); color: var(--fam-ink);
            text-decoration: none; font-weight: 700; font-size: 0.95rem;
            border-radius: 6px; transition: all 0.25s;
            box-shadow: 0 4px 20px rgba(201,168,76,0.35);
          }
          .ft-btn-primary:hover { background: #e8c456; transform: translateY(-2px); color: var(--fam-ink); text-decoration: none; }
          .ft-btn-outline {
            display: inline-flex; align-items: center; gap: 0.5rem;
            padding: 0.9rem 2.2rem; background: transparent; color: #fff;
            text-decoration: none; font-weight: 600; font-size: 0.95rem;
            border-radius: 6px; border: 1.5px solid rgba(255,255,255,0.4);
          }
          .ft-btn-outline:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.8); color: #fff; text-decoration: none; }
          .ft-hero-indicators {
            position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
            z-index: 4; display: flex; gap: 0.5rem;
          }
          .ft-hero-dot {
            width: 6px; height: 6px; border-radius: 3px;
            background: rgba(255,255,255,0.35); border: none; cursor: pointer;
            transition: all 0.3s; padding: 0;
          }
          .ft-hero-dot.active { background: var(--fam-gold); width: 24px; }
          .ft-scroll-hint {
            position: absolute; bottom: 2rem; right: 3rem; z-index: 4;
            display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
            color: rgba(255,255,255,0.4); font-size: 0.68rem; letter-spacing: 0.15em;
            text-transform: uppercase; opacity: 0; animation: ftFadeUp 1s 1.2s ease forwards;
          }
          .ft-scroll-line {
            width: 1px; height: 40px;
            background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
            animation: ftScrollPulse 2s ease-in-out infinite;
          }
          @keyframes ftScrollPulse {
            0%,100% { transform: scaleY(1); opacity: 0.4; }
            50% { transform: scaleY(0.55); opacity: 0.12; }
          }
          
          /* Stats Bar */
          .ft-stats-bar { background: var(--fam-navy); border-bottom: 1px solid rgba(255,255,255,0.06); }
          .ft-stats-inner { max-width: 1240px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: repeat(4, 1fr); }
          .ft-stat-item { padding: 2rem 1.5rem; text-align: center; border-right: 1px solid rgba(255,255,255,0.06); }
          .ft-stat-item:last-child { border-right: none; }
          .ft-stat-num { font-family: 'Inter', sans-serif; font-size: 2.4rem; font-weight: 800; color: var(--fam-gold); line-height: 1; margin-bottom: 0.35rem; }
          .ft-stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.55); font-weight: 500; }
          
          /* Scroll Reveal */
          .ft-reveal { opacity: 0; transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
          .ft-reveal.up { transform: translateY(48px); }
          .ft-reveal.left { transform: translateX(48px); }
          .ft-reveal.scale { transform: scale(0.92); }
          .ft-reveal.visible { opacity: 1; transform: none !important; }
          
          /* General Sections */
          .ft-section { padding: 7rem 0; }
          .ft-container { max-width: 1240px; margin: 0 auto; padding: 0 2rem; }
