            font-size: 0.8rem; font-weight: 600; padding: 0.4rem 0.9rem;
            border-radius: 30px; display: flex; align-items: center; gap: 0.3rem;
          }
          
          /* Solutions */
          .ft-solutions-section { background: var(--fam-navy); overflow: hidden; }
          .ft-solutions-inner { display: grid; grid-template-columns: 1fr 1fr; min-height: 560px; }
          .ft-solutions-left { padding: 6rem 4rem 6rem 2rem; display: flex; flex-direction: column; justify-content: center; max-width: 560px; margin: 0 auto; }
          .ft-solutions-left .ft-heading { color: #fff; }
          .ft-solutions-left .ft-subtext { color: rgba(255,255,255,0.65); max-width: 440px; }
          .ft-solutions-list { margin: 2rem 0; display: flex; flex-direction: column; gap: 1rem; }
          .ft-solutions-item {
            display: flex; align-items: flex-start; gap: 1rem;
