          .ft-product-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
          .ft-product-card p { font-size: 0.88rem; color: var(--fam-slate); line-height: 1.6; margin: 0; }
          .ft-product-card-link {
            position: absolute; inset: 0; display: flex; align-items: flex-end; justify-content: flex-end;
