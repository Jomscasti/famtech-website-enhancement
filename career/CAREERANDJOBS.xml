    <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function() {
      var heroSlides = document.querySelectorAll('.ft-hero-slide');
      var heroDots = document.querySelectorAll('.ft-hero-dot');
      var heroIdx = 0;
      function goHero(next) {
        heroSlides[heroIdx].classList.remove('active');
        heroDots[heroIdx].classList.remove('active');
        heroIdx = next;
        heroSlides[heroIdx].classList.add('active');
        heroDots[heroIdx].classList.add('active');
      }
      setInterval(function() { goHero((heroIdx + 1) % heroSlides.length); }, 7000);
      heroDots.forEach(function(dot, i) { dot.addEventListener('click', function() { goHero(i); }); });

      var revealEls = document.querySelectorAll('.ft-reveal');
      var revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) entry.target.classList.add('visible');
          else entry.target.classList.remove('visible');
        });
      }, { threshold: 0.08 });
      revealEls.forEach(function(el) { revealObs.observe(el); });

      document.querySelectorAll('[data-ft-count]').forEach(function(el) {
        var target = parseInt(el.getAttribute('data-ft-count'), 10);
        var suffix = el.getAttribute('data-ft-suffix') || '';
        var started = false;
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting &amp;&amp; !started) {
              started = true;
              var t0 = performance.now();
              var dur = 1400;
              function tick(now) {
                var p = Math.min((now - t0) / dur, 1);
                var ease = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(target * ease) + suffix;
                if (p &lt; 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
            } else if (!entry.isIntersecting) {
              started = false;
              el.textContent = '0' + suffix;
            }
          });
        }, { threshold: 0.3 });
        obs.observe(el);
      });
    });
    </script>
